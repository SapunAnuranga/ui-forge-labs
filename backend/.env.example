# Server port
PORT=5000

# JWT secret - change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_key

# Default admin login (used only on first run to create admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Stripe keys (use your own test/live keys from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (used for Stripe redirect after payment)
FRONTEND_URL=http://localhost:5173
